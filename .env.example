# Gitee API 配置
# 用于获取 Gitee Issues 数据（web.astro 和 shuoshuo.astro 的动态功能）
PUBLIC_GITEE_TOKEN=your_gitee_token_here
PUBLIC_GITEE_OWNER=kemiaoshiwo
PUBLIC_GITEE_REPO=main

# 自定义头像和名称（可选）
# 如果不设置，将使用 Gitee 用户的默认头像和用户名
PUBLIC_CUSTOM_AVATAR=https://example.com/avatar.png
PUBLIC_CUSTOM_NAME=异飨客

# ============================================
# AI 摘要配置 (AISummary)
# ============================================
# AI 摘要服务地址（你的 Vercel 部署地址）
AI_SUMMARY_API=https://ai.zsxcoder.top/api/spark-proxy

# API 密钥（如果使用需要认证的 API）
AI_SUMMARY_KEY=

# 使用的模型名称
AI_SUMMARY_MODEL=lite

# 并发处理数（建议 1-5）
AISUMMARY_CONCURRENCY=2

# 是否重新生成所有摘要（true/false）
AISUMMARY_COVER_ALL=false

# 用于截取文章内容的最大 Token 数
AISUMMARY_MAX_TOKEN=5000

# 文章最小内容长度（小于此长度跳过）
AISUMMARY_MIN_CONTENT_LENGTH=50
