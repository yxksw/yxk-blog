---
import PageLayout from '@/layouts/PageLayout.astro'
import FriendList from '@/components/links/FriendList.astro'
import FriendBadgeLegend from '@/components/links/FriendBadgeLegend.astro'
import { links, specialLinks } from '@/links.config'
import siteConfig from '@/config.json'

const commonLinks = links.filter(link => !link.disconnected)
const disconnectedLinks = links.filter(link => link.disconnected)

const applyTip = [
  { name: '名称', val: siteConfig.site.title || 'Lanke' },
  { name: '描述', val: siteConfig.site.description || 'Lanke的博客' },
  { name: '链接', val: siteConfig.site.url || 'https://blog.blueke.top' },
  { name: '头像', val: siteConfig.author.avatar || '' },
]
---

<PageLayout title='友链' description='我的朋友们和特别链接'>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-center">友链</h1>
    
    <!-- Common Links -->
    <section class="mb-12">
      <h2 id="common-links" class="text-xl font-semibold mb-4 pb-2 border-b border-border">
        Common Links
      </h2>
      <FriendList links={commonLinks} />
    </section>

    <!-- Disconnected Links -->
    {
      disconnectedLinks.length > 0 && (
        <details class="mb-4 group">
          <summary class="flex items-center justify-between cursor-pointer list-none rounded-lg border border-border bg-secondary/30 px-4 py-3 transition-colors hover:bg-secondary/50">
            <span class="text-base font-medium text-muted-foreground">Links with Bad Status</span>
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              width="20" 
              height="20" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2" 
              stroke-linecap="round" 
              stroke-linejoin="round"
              class="transition-transform duration-300 group-open:rotate-90"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </summary>
          <div class="pt-4">
            <FriendList links={disconnectedLinks} />
          </div>
        </details>
      )
    }

    <!-- Badge Legend -->
    <details class="mb-12 group">
      <summary class="flex items-center justify-between cursor-pointer list-none rounded-lg border border-border bg-secondary/30 px-4 py-3 transition-colors hover:bg-secondary/50">
        <span class="text-base font-medium">Imprint Legend</span>
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          width="20" 
          height="20" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round"
          class="transition-transform duration-300 group-open:rotate-90"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </summary>
      <div class="pt-4">
        <FriendBadgeLegend />
      </div>
    </details>

    <!-- Special Links -->
    <section class="mb-12">
      <h2 id="special-links" class="text-xl font-semibold mb-4 pb-2 border-b border-border">
        Special Links
      </h2>
      {
        specialLinks.length > 0 ? (
          <FriendList links={specialLinks} isSpecial={true} />
        ) : (
          <p class="text-muted-foreground">Special links will be displayed here.</p>
        )
      }
    </section>

    <!-- Small Circle -->
    <section class="mb-12">
      <h2 id="small-circle" class="text-xl font-semibold mb-4 pb-2 border-b border-border">
        Small Circle
      </h2>
      <div id="friend-circle-lite-root" class="not-prose">Loading...</div>
    </section>

    <!-- Apply Links -->
    <section class="mb-12">
      <h2 id="apply-links" class="text-xl font-semibold mb-4 pb-2 border-b border-border">
        Apply Links
      </h2>
      <p class="mb-4">本站信息（点击复制）The site information (click to copy)：</p>
      <blockquote class="not-prose grid grid-cols-[auto_1fr] gap-x-2 gap-y-2 break-words border-s-4 border-border ps-4 py-2 bg-secondary/50 rounded-r-lg">
        {
          applyTip.map(({ name, val }) => {
            const script = `navigator.clipboard.writeText('${val}');document.dispatchEvent(new CustomEvent('toast',{detail:{message:'Copied "${val}" to clipboard!'}}))`
            return (
              <>
                <span class="text-end font-medium text-sm">{name}:</span>
                <samp class="cursor-pointer font-sans font-normal text-sm hover:text-accent transition-colors" onclick={script}>
                  {val}
                </samp>
              </>
            )
          })
        }
      </blockquote>

      <div class="mt-6 space-y-4">
        <p>
          可通过下方留言或
          <a href={`mailto:${siteConfig.author?.twitterId || ''}`} class="underline hover:text-accent transition-colors">
            发送邮件
          </a>
          申请友链。申请说明：
          <br />
          Apply your link by leaving a comment or
          <a href={`mailto:${siteConfig.author?.twitterId || ''}`} class="underline hover:text-accent transition-colors">
            sending an email
          </a>
          . Additional info:
        </p>
        <ul class="list-disc list-inside space-y-1 text-sm text-muted-foreground">
          <li>推荐了本站 You've recommended our link on your website</li>
          <li>站点活着且有正式域名 Make sure your site is alive with a formal domain</li>
          <li>至少五篇原创文章且最近一年更新过 At least 5 original articles and exists articles released in recent year</li>
          <li>内容不违反国家法律 Content does not violate laws</li>
        </ul>
      </div>
    </section>
  </div>
<script>
    import '@/styles/fc.css'
    import { FriendCircle } from '@/plugins/friendCircle'

    const fc = new FriendCircle()
    fc.init({
      private_api_url: 'https://fc.050815.xyz/',
      page_turning_number: 10,
      error_img: 'https://gravatar.loli.net/avatar/57d8260dfb55501c37dde588e7c3852c'
    })
    fc.load()
  </script>
</PageLayout>
