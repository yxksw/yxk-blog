---
import PageLayout from '@/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

interface EquipmentInfo {
  [key: string]: string;
}

interface EquipmentItem {
  name: string;
  image: string;
  src: string;
  category: string;
  desc: string;
  info: EquipmentInfo;
  tags: string[];
  date: string;
  money: number;
}

interface EquipmentCategory {
  key: string;
  label: string;
  icon: string;
  color: string;
}

interface EquipmentData {
  categories: EquipmentCategory[];
  items: EquipmentItem[];
}

// 获取装备数据
let equipmentData: EquipmentData | null = null;
let fetchError = '';

try {
  const response = await fetch('https://cdn.jsdmirror.com/gh/yxksw/yxksw@main/public/data/equipment.json');
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  equipmentData = await response.json();
} catch (error) {
  fetchError = error instanceof Error ? error.message : '获取装备数据失败';
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: '首页',
      item: Astro.site,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: '装备',
      item: new URL('/equipment/', Astro.site).toString(),
    },
  ],
};

// 格式化日期
function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// 格式化金额
function formatMoney(money: number): string {
  return new Intl.NumberFormat('zh-CN', {
    style: 'currency',
    currency: 'CNY',
    minimumFractionDigits: 0,
  }).format(money);
}
---

<PageLayout title="装备" description="我的装备清单">
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- 页面标题 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-10 w-10 rounded-lg bg-accent flex items-center justify-center shrink-0">
          <Icon name="lucide:package" class="text-xl text-accent-foreground" />
        </div>
        <h1 class="text-2xl font-bold text-foreground">装备清单</h1>
      </div>
      <p class="text-muted-foreground">记录我的硬件设备和外设装备</p>
    </div>

    {fetchError && (
      <div class="rounded-lg border border-red-400/30 bg-red-500/10 p-4 text-sm text-red-500 mb-6">
        加载失败：{fetchError}
      </div>
    )}

    {equipmentData && (
      <div class="space-y-8">
        {equipmentData.categories.map((category) => {
          const categoryItems = equipmentData!.items.filter(item => item.category === category.key);
          if (categoryItems.length === 0) return null;
          
          return (
            <section class="card-base rounded-xl border border-border bg-card p-6">
              <!-- 分类标题 -->
              <div class="flex items-center gap-3 mb-6">
                <div 
                  class="h-8 w-8 rounded-lg flex items-center justify-center shrink-0"
                  style={`background-color: ${category.color}20; color: ${category.color};`}
                >
                  <Icon name={`lucide:${category.icon.toLowerCase()}`} class="text-lg" />
                </div>
                <h2 class="text-xl font-semibold text-foreground">{category.label}</h2>
                <span class="text-sm text-muted-foreground">({categoryItems.length})</span>
              </div>

              <!-- 装备列表 -->
              <div class="grid gap-4 md:grid-cols-2">
                {categoryItems.map((item) => (
                  <a 
                    href={item.src}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex gap-4 p-4 rounded-lg border border-border bg-secondary/30 hover:bg-secondary/50 transition-colors"
                  >
                    <!-- 图片 -->
                    <div class="shrink-0">
                      <img 
                        src={item.image} 
                        alt={item.name}
                        class="w-24 h-24 object-contain rounded-lg bg-background"
                        loading="lazy"
                      />
                    </div>

                    <!-- 内容 -->
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2 mb-2">
                        <h3 class="font-semibold text-foreground group-hover:text-accent transition-colors line-clamp-1">
                          {item.name}
                        </h3>
                        <span class="text-sm font-medium text-accent shrink-0">
                          {formatMoney(item.money)}
                        </span>
                      </div>

                      <p class="text-sm text-muted-foreground mb-3 line-clamp-2">
                        {item.desc}
                      </p>

                      <!-- 规格信息 -->
                      <div class="flex flex-wrap gap-2 mb-3">
                        {Object.entries(item.info).slice(0, 3).map(([key, value]) => (
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-background border border-border">
                            <span class="text-muted-foreground">{key}:</span>
                            <span class="ml-1 text-foreground truncate max-w-[100px]">{value}</span>
                          </span>
                        ))}
                      </div>

                      <!-- 标签和日期 -->
                      <div class="flex items-center justify-between text-xs text-muted-foreground">
                        <div class="flex gap-1">
                          {item.tags.slice(0, 3).map((tag) => (
                            <span class="px-1.5 py-0.5 rounded bg-accent/10 text-accent">
                              {tag}
                            </span>
                          ))}
                        </div>
                        <span>{formatDate(item.date)}</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    )}
  </div>
</PageLayout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
