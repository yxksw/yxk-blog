---
import PageLayout from '@/layouts/PageLayout.astro'
import siteConfig from '@/config.json'
import aboutData from '@/data/about.json'
import Single from '@/components/Single.astro'
import { Icon } from '@iconify/react'

// 判断是否为 iconify 图标名（格式如：ri:github-line）
function isIconifyIcon(icon: string): boolean {
  return /^[a-z0-9-]+:[a-z0-9-]+$/i.test(icon)
}
---

<PageLayout title="关于我" description={siteConfig.site.description}>
  <div id="about-container" class="max-w-6xl mx-auto px-4 py-8">
    <!-- Top Section -->
    <section class="top-section">
      <div class="top-content">
        <div class="float-texts">
          {aboutData.top_info.float_text.slice(0, 4).map((text, index) => (
            <div class={`float-text float-text-${index + 1}`}>{text}</div>
          ))}
        </div>
        <div class="avatar-container">
          <img 
            class="no-lightbox avatar" 
            src={aboutData.top_info.avatar} 
            onerror="this.onerror=null;this.src='https://gravatar.loli.net/avatar/57d8260dfb55501c37dde588e7c3852c'" 
            alt="avatar"
          />
        </div>
        <div class="float-texts">
          {aboutData.top_info.float_text.slice(4, 8).map((text, index) => (
            <div class={`float-text float-text-${index + 5}`}>{text}</div>
          ))}
        </div>
      </div>
      <div class="site-name">{aboutData.top_info.site_name}</div>
      <div class="motto">{aboutData.top_info.motto}</div>
    </section>

    <!-- Info Section -->
    <section class="info-section">
      <div class="left-column card">
        <div class="personal-info">
          <h2 class="section-title">个人信息</h2>
          <div class="info-grid">
            <p><strong>姓名:</strong> {aboutData.personal_info.name}</p>
            <p><strong>性别:</strong> {aboutData.personal_info.gender}</p>
            <p><strong>地址:</strong> {aboutData.personal_info.address}</p>
            <p><strong>学校:</strong> {aboutData.personal_info.school}</p>
            <p><strong>年级:</strong> {aboutData.personal_info.grade}</p>
            <p><strong>专业:</strong> {aboutData.personal_info.major}</p>
            <p><strong>邮箱:</strong> <a href={`mailto:${aboutData.personal_info.email}`}>{aboutData.personal_info.email}</a></p>
            <p><strong>QQ:</strong> {aboutData.personal_info.QQ}</p>
            <p><strong>生日:</strong> {aboutData.personal_info.birthday}</p>
          </div>
        </div>
        <div class="flex-1"></div>
        <img 
          class="left-column-bottom" 
          src={aboutData.personal_info.bottom_img} 
          onerror="this.onerror=null;this.src='https://gravatar.loli.net/avatar/57d8260dfb55501c37dde588e7c3852c'" 
          alt=""
        />
      </div>
      <div class="right-column">
        <div class="personality card">
          <div class="personality-info">
            <p class="type">{aboutData.personality.type}</p>
            <p class="type_name">{aboutData.personality.type_name}</p>
            <div class="flex-1"></div>
            <p class="learn_more">
              点击在 <a href={aboutData.personality.url} target="_blank" rel="noopener nofollower">16Personalities</a> 上了解更多
            </p>
          </div>
          <div class="personality-svg">
            <img 
              class="no-lightbox svg" 
              src={aboutData.personality.svg} 
              onerror="this.onerror=null;this.src='https://gravatar.loli.net/avatar/57d8260dfb55501c37dde588e7c3852c'" 
              alt="Personality SVG"
            />
          </div>
        </div>

        <div class="description-and-social card">
          <p class="description">{aboutData.description_and_social_links.description}</p>
          <div class="social-links">
            {aboutData.description_and_social_links.social_links.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-link">
                {isIconifyIcon(link.icon) ? (
                  <Icon icon={link.icon} className="social-icon" client:load />
                ) : (
                  <img 
                    class="no-lightbox social-img" 
                    src={link.icon} 
                    onerror="this.onerror=null;this.src='https://gravatar.loli.net/avatar/57d8260dfb55501c37dde588e7c3852c'" 
                    alt={link.platform}
                  />
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Skills and Careers -->
    <section class="skills-careers-container">
      <!-- 技能展示 -->
      <div class="skills card author-content-item">
        <div class="card-content">
          <div class="author-content-item-tips">{aboutData.skills.subtitle}</div>
          <span class="author-content-item-title">{aboutData.skills.title}</span>
          <div class="skills-style-group">
            <!-- 滚动技能图标 -->
            <div id="skills-tags-group-all">
              <div class="tags-group-wrapper">
                {Array.from({ length: Math.ceil(aboutData.skills.icons.length / 2) }).map((_, index) => {
                  const skill1 = aboutData.skills.icons[index * 2]
                  const skill2 = aboutData.skills.icons[index * 2 + 1]
                  return (
                    <div class="tags-group-icon-pair">
                      {skill1 && (
                        <div class="tags-group-icon" style={`background: ${skill1.background}`} title={skill1.title}>
                          <img class="no-lightbox" src={skill1.image} alt={skill1.title} />
                        </div>
                      )}
                      {skill2 && (
                        <div class="tags-group-icon" style={`background: ${skill2.background}`} title={skill2.title}>
                          <img class="no-lightbox" src={skill2.image} alt={skill2.title} />
                        </div>
                      )}
                    </div>
                  )
                })}
                {/* 复制一份用于无限滚动 */}
                {Array.from({ length: Math.ceil(aboutData.skills.icons.length / 2) }).map((_, index) => {
                  const skill1 = aboutData.skills.icons[index * 2]
                  const skill2 = aboutData.skills.icons[index * 2 + 1]
                  return (
                    <div class="tags-group-icon-pair">
                      {skill1 && (
                        <div class="tags-group-icon" style={`background: ${skill1.background}`} title={skill1.title}>
                          <img class="no-lightbox" src={skill1.image} alt={skill1.title} />
                        </div>
                      )}
                      {skill2 && (
                        <div class="tags-group-icon" style={`background: ${skill2.background}`} title={skill2.title}>
                          <img class="no-lightbox" src={skill2.image} alt={skill2.title} />
                        </div>
                      )}
                    </div>
                  )
                })}
              </div>
            </div>

            <!-- 技能列表（悬停时显示） -->
            <div class="skills-list">
              {aboutData.skills.icons.slice(0, 16).map((skill) => (
                <div class="skill-info">
                  <div class="skill-icon" style={`background: ${skill.background}`}>
                    <img class="no-lightbox" src={skill.image} alt={skill.title} />
                  </div>
                  <div class="skill-name">
                    <span>{skill.title}</span>
                  </div>
                </div>
              ))}
              <div class="etc">...</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 生涯经历 -->
      <div class="careers card author-content-item">
        <div class="card-content">
          <div class="author-content-item-tips">生涯</div>
          <span class="author-content-item-title">无限进步</span>
          <div class="careers-group">
            {aboutData.skills.careers.map((career) => (
              <div class="careers-item">
                <div class="circle" style={`background: ${career.color}`}></div>
                <div class="name">{career.name}</div>
              </div>
            ))}
          </div>
          <img class="author-content-img no-lightbox" alt="生涯" src="https://mcy.zsxcoder.top/sy.png" />
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="projects-section">
      <div class="projects card">
        <h2 class="section-title">项目</h2>
        <div class="projects-scroll-container">
          <div class="projects-grid">
            {aboutData.projects.map((project) => (
              <div class="project">
                <a href={project.url} target="_blank" rel="noopener noreferrer">
                  <h3>{project.name}</h3>
                  <p>{project.description}</p>
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Hobbies and Evaluation -->
    <section class="hobbies-and-evaluation">
      <div class="hobbies card">
        <h2 class="section-title">爱好</h2>
        <ul class="hobbies-list">
          {aboutData.hobbies.map((hobby) => (
            <li>{hobby}</li>
          ))}
        </ul>
      </div>
      <div class="self-evaluation card">
        <h2 class="section-title">评价</h2>
        <p><strong>思想:</strong> {aboutData.self_evaluation.thoughts}</p>
        <p><strong>工作:</strong> {aboutData.self_evaluation.work}</p>
        <p class="summary"><strong>总结:</strong> {aboutData.self_evaluation.summary}</p>
      </div>
    </section>

    <!-- Single Component -->
    <section class="single-section">
      <Single />
    </section>
  </div>
</PageLayout>

<style>
  @import '@/styles/me.css';
</style>
