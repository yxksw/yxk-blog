---
import {
  CommonHead,
  WebAnalytics,
  ThemeLoader,
  AccentColorInjector,
  PrintVersion,
} from '@/components/head'
import { BackToTopFAB } from '@/components/BackToTopFAB'
import { ToastContainer } from '@/components/ToastContainer'
import { ModalStack } from '@/components/ui/modal'
import Lightbox from '@/components/Lightbox.astro'
import FootnoteTooltip from '@/components/FootnoteTooltipInline.astro'
import NewPostNotification from '@/components/NewPostNotification.astro'
import PostChangeHighlighter from '@/components/PostChangeHighlighter.astro'
import MusicPlayer from '@/components/MusicPlayer.svelte'
import config from '@/config.json'
import '@/styles/global.css'

interface Props {
  title?: string
  description?: string
  image?: string
}

const { title, description, image } = Astro.props
---

<!doctype html>
<html lang={config.site.lang}>
  <head>
    <CommonHead title={title} description={description} image={image} />
    <WebAnalytics />
    <ThemeLoader />
    <AccentColorInjector />
    <PrintVersion />
    <script>
      import 'iconify-icon'
    </script>
  </head>
  <body>
    <slot />

    <BackToTopFAB client:only="react" />
    <ToastContainer client:only="react" />
    <ModalStack client:only="react" />
    <Lightbox />
    <FootnoteTooltip />
    <NewPostNotification />
    <PostChangeHighlighter />
    <MusicPlayer client:only="svelte" config={config.musicPlayer as any} />
    <script>
      import { initLivecodes } from '@/scripts/livecodes.ts'
      document.addEventListener('astro:page-load', () => initLivecodes())
      initLivecodes()
    </script>
  </body>
</html>
