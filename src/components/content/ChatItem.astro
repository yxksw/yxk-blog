---
// ChatItem 组件 - 聊天消息项
// type: 'left' | 'right' | 'system'
// name: 发送者名称

interface Props {
  type?: 'left' | 'right' | 'system'
  name?: string
}

const { type = 'left', name } = Astro.props

const isSystem = type === 'system'
const isMyself = type === 'right'
---

{
  isSystem ? (
    <dt class="chat-caption chat-system"><slot /></dt>
  ) : (
    <>
      {name && <dt class:list={['chat-caption', { 'chat-myself': isMyself }]}>{name}</dt>}
      <dd class="chat-body"><slot /></dd>
    </>
  )
}
