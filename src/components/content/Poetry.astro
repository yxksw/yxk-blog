---
// Poetry 组件 - 诗词展示组件
// 用于展示诗歌、诗词等内容

interface Props {
  title?: string
  author?: string
  footer?: string
}

const { title, author, footer } = Astro.props
---

<section class="poetry">
  {title && <h2 class="poetry-title">{title}</h2>}
  {author && <div class="poetry-author">{author}</div>}
  <div class="poetry-content">
    <slot />
  </div>
  {footer && <div class="poetry-footer">{footer}</div>}
</section>

<style>
  .poetry {
    width: fit-content;
    margin: 0.8em auto;
    white-space: pre-wrap;
    text-align: center;
    line-height: 1.4;
  }

  .poetry-title {
    font-size: 1.2em;
    font-weight: 600;
    margin-bottom: 0.1em;
    color: rgb(var(--color-text-primary));
  }

  .poetry-author {
    font-size: 0.9em;
    color: rgb(var(--color-text-secondary));
    margin-bottom: 0.05em;
  }

  .poetry-content {
    color: rgb(var(--color-text-primary));
  }

  .poetry-content :global(p) {
    width: fit-content;
    margin: 0.05em auto;
    line-height: 1.4;
  }

  .poetry-footer {
    font-size: 0.85em;
    color: rgb(var(--color-text-secondary));
    margin-top: 0.05em;
    font-style: italic;
  }
</style>
