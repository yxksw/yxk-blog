---
import { Icon } from 'astro-icon/components'
import config from '@/config.json'
import { formatPostDateForDisplay } from '@/utils/date-utils'

interface Props {
  title: string
  slug: string
  pubDate: Date
  class?: string
}

const { title, pubDate } = Astro.props
const className = Astro.props.class
const author = config.author
const license = config.license
const postUrl = decodeURIComponent(Astro.url.toString())
---

<div class={`license-wrapper ${className}`}>
  <div class="license-title">
    {title}
  </div>

  <a id="current-link" class="license-link"></a>

  <script>
    const currentLink = document.getElementById('current-link') as HTMLAnchorElement | null;

    if (currentLink) {
      const oldUrl = window.location.href;
      const url = new URL(oldUrl);
      url.search = ''; // 移除查询字符串
      if (url.hash.includes('giscus-')) {
        url.hash = ''; // 移除 #giscus-xxx 的 hash
      }
      const newUrl = url.toString();
      if (oldUrl !== newUrl) {
        console.log(`[license] replaced url: ${oldUrl} -> ${newUrl}`);
      }

      currentLink.textContent = newUrl;
      currentLink.href = newUrl;
    }
  </script>

  <div class="license-meta">
    <div class="license-meta-item">
      <div class="license-meta-label">作者</div>
      <div class="license-meta-value">{author.name}</div>
    </div>
    <div class="license-meta-item">
      <div class="license-meta-label">发布于</div>
      <div class="license-meta-value">{formatPostDateForDisplay(pubDate)}</div>
    </div>
    <div class="license-meta-item">
      <div class="license-meta-label">许可协议</div>
      <a href={license.url} target="_blank" class="license-meta-link">{license.name}</a>
    </div>
  </div>
  <Icon name="ri:creative-commons-line" class="license-bg-icon" />
</div>

<style>
  .license-wrapper {
    position: relative;
    overflow: hidden;
    padding: 1.25rem 1.5rem;
    background-color: rgba(var(--color-bg-secondary), 0.5);
    border: 1px solid rgb(var(--color-border-primary));
    border-radius: 0.75rem;
    transition: all 0.3s ease;
  }

  .license-title {
    font-weight: 700;
    color: rgb(var(--color-text-primary));
    margin-bottom: 0.25rem;
  }

  .license-link {
    display: inline-block;
    color: rgb(var(--color-accent));
    font-size: 0.875rem;
    word-break: break-all;
    margin-bottom: 0.75rem;
    transition: opacity 0.2s ease;
  }

  .license-link:hover {
    opacity: 0.8;
  }

  .license-meta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .license-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .license-meta-label {
    font-size: 0.75rem;
    color: rgb(var(--color-text-muted));
  }

  .license-meta-value {
    font-size: 0.875rem;
    color: rgb(var(--color-text-primary));
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .license-meta-link {
    font-size: 0.875rem;
    color: rgb(var(--color-accent));
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: opacity 0.2s ease;
  }

  .license-meta-link:hover {
    opacity: 0.8;
  }

  .license-wrapper :global(.license-bg-icon) {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 15rem !important;
    height: 15rem !important;
    color: rgb(var(--color-text-muted));
    opacity: 0.05;
    pointer-events: none;
    transition: color 0.3s ease;
  }
</style>
