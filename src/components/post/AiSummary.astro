---
interface Props {
  slug: string
  title: string
  body: string
  embedded?: boolean
}

const { slug, title, body, embedded = false } = Astro.props
const apiBaseUrl = 'https://summary.261770.xyz/https/ai.261770.xyz'

const containerClass = embedded
  ? 'p-4 transition ai-summary-card data-pagefind-ignore'
  : 'mb-6 p-4 rounded-lg bg-amber-300/10 border border-amber-300 transition ai-summary-card data-pagefind-ignore'
---

<div id={`ai-summary-${slug}`} class={containerClass} data-slug={slug} data-title={title} data-body={body} data-api-base-url={apiBaseUrl}>
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-2 font-bold">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-6 h-6"
        ><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path
          d="M2 14h2"
        ></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg
      >
      <span>AI 摘要</span>
    </div>
    <button
      id={`ai-summary-refresh-${slug}`}
      class="p-1.5 rounded-full hover:bg-amber-400/20 transition-colors cursor-pointer"
      title="重新生成摘要"
      aria-label="重新生成摘要"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-4 h-4"
      >
        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
        <path d="M3 3v5h5"></path>
        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
        <path d="M16 16h5v5"></path>
      </svg>
    </button>
  </div>
  <p id={`ai-summary-text-${slug}`} class="text-sm leading-relaxed opacity-80 break-words">
    正在生成中...
  </p>
</div>

<script is:inline>
  // SHA256 哈希函数
  async function sha256(str) {
    const encoder = new TextEncoder()
    const data = encoder.encode(str)
    const hashBuffer = await crypto.subtle.digest('SHA-256', data)
    const hashArray = Array.from(new Uint8Array(hashBuffer))
    return hashArray.map((b) => b.toString(16).padStart(2, '0')).join('')
  }

  // 生成摘要的主函数
  async function generateSummary(container, forceRefresh = false) {
    const slug = container.dataset.slug
    const title = container.dataset.title
    const body = container.dataset.body
    const apiBaseUrl = container.dataset.apiBaseUrl
    const outputEl = document.getElementById(`ai-summary-text-${slug}`)
    const refreshBtn = document.getElementById(`ai-summary-refresh-${slug}`)

    if (!outputEl) {
      console.error('输出元素未找到')
      return
    }

    // 添加旋转动画
    if (refreshBtn) {
      refreshBtn.classList.add('animate-spin')
      refreshBtn.disabled = true
    }

    try {
      // 1. 获取文章完整文本
      const articleText = `标题: ${title}\n\n${body}`

      // 2. 计算内容的 SHA256 哈希
      const contentHash = await sha256(articleText)

      // 3. 如果不是强制刷新，先检查缓存
      if (!forceRefresh) {
        const checkUrl = `${apiBaseUrl}/is_uploaded?id=${encodeURIComponent(slug)}&sign=${encodeURIComponent(contentHash)}`
        const checkRes = await fetch(checkUrl)
        const isUploaded = await checkRes.text()

        // 4. 若内容未上传或已变更，则上传新内容
        if (isUploaded !== 'yes') {
          const uploadUrl = `${apiBaseUrl}/upload_blog?id=${encodeURIComponent(slug)}`
          const uploadRes = await fetch(uploadUrl, {
            method: 'POST',
            body: articleText,
            headers: { 'Content-Type': 'text/plain' },
          })

          if (!uploadRes.ok) {
            throw new Error(`上传失败: ${uploadRes.status}`)
          }
        }

        // 5. 尝试获取已缓存的摘要
        const getSummaryUrl = `${apiBaseUrl}/get_summary?id=${encodeURIComponent(slug)}&sign=${encodeURIComponent(contentHash)}`
        const summaryRes = await fetch(getSummaryUrl)
        const cachedSummary = await summaryRes.text()

        if (cachedSummary && cachedSummary !== 'no') {
          outputEl.textContent = cachedSummary
          return
        }
      } else {
        // 强制刷新：重新上传内容（添加随机参数绕过缓存）
        outputEl.textContent = '正在重新生成摘要...'
        const cacheBuster = `&_t=${Date.now()}`
        const uploadUrl = `${apiBaseUrl}/upload_blog?id=${encodeURIComponent(slug)}${cacheBuster}`
        try {
          const uploadRes = await fetch(uploadUrl, {
            method: 'POST',
            body: articleText,
            headers: { 'Content-Type': 'text/plain' },
          })
          if (!uploadRes.ok) {
            throw new Error(`上传失败: ${uploadRes.status}`)
          }
        } catch (uploadErr) {
          console.warn('重新上传失败，尝试直接生成:', uploadErr)
          // 上传失败也继续尝试生成
        }
      }

      // 6. 生成新摘要
      outputEl.textContent = '正在生成摘要，请稍候...'
      // 添加随机参数绕过缓存
      const cacheBuster = forceRefresh ? `&_t=${Date.now()}` : ''
      const streamUrl = `${apiBaseUrl}/summary?id=${encodeURIComponent(slug)}${cacheBuster}`
      const streamRes = await fetch(streamUrl, {
        method: 'GET',
        headers: {
          'Accept': 'text/event-stream',
        },
      })

      if (!streamRes.ok) {
        throw new Error(`生成摘要失败: ${streamRes.status}`)
      }

      // 处理流式响应
      const reader = streamRes.body?.getReader()
      if (!reader) {
        throw new Error('无法读取响应流')
      }

      let summary = ''
      const decoder = new TextDecoder()
      outputEl.textContent = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break

        const chunk = decoder.decode(value)
        const lines = chunk.split('\n')

        for (const line of lines) {
          if (line.startsWith('data: ')) {
            const data = line.slice(6)
            if (data === '[DONE]') continue

            try {
              const parsed = JSON.parse(data)
              if (parsed.response) {
                summary += parsed.response
                outputEl.textContent = summary
              }
            } catch (e) {
              // 忽略解析错误
            }
          }
        }
      }
    } catch (err) {
      console.error('AI摘要生成错误:', err)
      // 检查是否是CORS错误
      if (err.message.includes('CORS') || err.message.includes('Failed to fetch')) {
        outputEl.textContent = '摘要服务暂不可用，请在生产环境或部署后重试。'
      } else {
        outputEl.textContent = `摘要生成失败: ${err.message}`
      }
      outputEl.style.color = 'red'
    } finally {
      // 移除旋转动画
      if (refreshBtn) {
        refreshBtn.classList.remove('animate-spin')
        refreshBtn.disabled = false
      }
    }
  }

  // 添加延迟，确保 DOM 完全加载
  setTimeout(() => {
    const containers = document.querySelectorAll('[data-slug]')
    containers.forEach(container => {
      const slug = container.dataset.slug
      const refreshBtn = document.getElementById(`ai-summary-refresh-${slug}`)
      
      // 绑定刷新按钮点击事件
      if (refreshBtn) {
        refreshBtn.addEventListener('click', () => {
          generateSummary(container, true)
        })
      }
      
      // 初始生成摘要
      generateSummary(container, false)
    })
  }, 500)
</script>
