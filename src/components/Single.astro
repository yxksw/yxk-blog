---
import { getCollection, render } from 'astro:content'
import { getEntrySlug } from '@/utils/content'

// 获取 about.md 内容
const aboutPosts = await getCollection('spec')
const aboutPost = aboutPosts.find((entry) => getEntrySlug(entry) === 'about')

let Content = null
if (aboutPost) {
  const rendered = await render(aboutPost)
  Content = rendered.Content
}

// 配置数据
const singleData = {
  tip: '关于博客'
}
---

<div class="author-content-item single">
  <div class="author-content-item-tips">
    {singleData.tip}
  </div>
  <div class="singlePost">
    {Content ? (
      <div class="article markdown-body">
        <Content />
      </div>
    ) : (
      <p class="text-center">
        可于 about.md 或 about.mdx 配置补充说明。
      </p>
    )}
  </div>
</div>

<style>
  .author-content-item.single {
    width: 100%;
    background-color: hsl(var(--secondary));
    border-radius: 12px;
    padding: 24px;
    border: 1px solid hsl(var(--border));
  }

  .author-content-item-tips {
    opacity: 0.8;
    font-size: 12px;
    margin-bottom: 0.5rem;
    color: hsl(var(--muted-foreground));
  }

  .singlePost {
    margin-top: 1rem;
  }

  .singlePost .article {
    color: hsl(var(--foreground));
  }

  .singlePost .article :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: hsl(var(--foreground));
  }

  .singlePost .article :global(p) {
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .singlePost .article :global(a) {
    color: hsl(var(--accent));
    text-decoration: none;
  }

  .singlePost .article :global(a:hover) {
    text-decoration: underline;
  }

  .singlePost .article :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .singlePost .article :global(li) {
    margin-bottom: 0.25rem;
  }

  .text-center {
    text-align: center;
    color: hsl(var(--muted-foreground));
    padding: 2rem 0;
  }
</style>
