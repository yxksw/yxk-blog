---
import { Icon } from 'astro-icon/components'
---

<style>
  #notification-panel {
    position: relative;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    overflow: hidden;
    box-sizing: border-box;
    transition:
      width 360ms cubic-bezier(0.4, 0, 0.2, 1),
      height 360ms cubic-bezier(0.4, 0, 0.2, 1),
      border-radius 360ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 260ms ease;
  }
  #notification-panel.is-open {
    width: var(--np-open-width, min(20rem, calc(100vw - 2rem)));
    height: var(--np-open-height, min(70vh, 34rem));
    border-radius: 1rem;
    display: block;
  }
  #notification-minimized {
    position: absolute;
    inset: 0;
    transition: opacity 160ms ease, transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1);
    border-radius: 50%;
  }
  #notification-panel.is-open #notification-minimized {
    border-radius: 1rem;
  }
  #notification-content {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 200ms ease, transform 260ms ease;
  }
  #notification-panel.is-open #notification-minimized {
    opacity: 0;
    pointer-events: none;
    transform: none;
  }
  #notification-panel.is-open #notification-bell-icon {
    display: none;
  }
  #notification-panel.is-open-content #notification-content {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>

<div id="new-post-notification" class="fixed right-4 bottom-[8rem] z-50 pointer-events-none">
  <div
    id="notification-panel"
    class="pointer-events-auto size-10 rounded-full shadow-lg shadow-zinc-800/5 border border-[rgb(var(--color-primary))] bg-[rgb(var(--color-bg-card))] text-[rgb(var(--color-primary))] transform translate-y-20 opacity-0 flex items-center justify-center cursor-pointer backdrop-blur-md"
  >
    <span id="notification-bell-icon">
      <Icon name="lucide:bell" size={20} />
    </span>
    <button id="notification-minimized" aria-label="New post notification" class="hidden">
      <Icon name="lucide:bell" size={20} />
    </button>

    <div id="notification-content" class="flex flex-col p-5">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2 text-[rgb(var(--color-primary))]">
          <Icon name="lucide:rss" size={20} />
          <h3 class="font-bold text-[rgb(var(--color-text))]">发现新文章</h3>
          <a href="/posts/post-diff-guide/#食用方法" class="ml-1 text-xs text-[rgb(var(--color-primary))] hover:underline opacity-80" title="查看食用方法">
            <Icon name="material-symbols:help-outline-rounded" size={16} />
          </a>
        </div>
        <div class="flex items-center gap-1">
          <button
            id="clear-notification"
            class="text-[rgb(var(--color-text-2))]/50 hover:text-red-500 transition-colors p-1 rounded-md hover:bg-red-500/10"
            title="清空通知"
          >
            <Icon name="material-symbols:delete-rounded" size={18} class="mx-auto" />
          </button>
          <button
            id="minimize-notification"
            class="text-[rgb(var(--color-text-2))]/50 hover:text-[rgb(var(--color-primary))] transition-colors p-1 rounded-md hover:bg-[rgb(var(--color-primary))]/10"
            title="隐藏"
          >
            <Icon name="material-symbols:close-rounded" size={18} class="mx-auto" />
          </button>
        </div>
      </div>
      <div id="new-post-list" class="text-sm text-[rgb(var(--color-text))]/80 transition-colors space-y-1 flex-1 overflow-y-auto overflow-x-hidden"></div>
    </div>
  </div>
  <span
    id="notification-dot"
    class="absolute top-0 right-0 w-3 h-3 bg-red-500 rounded-full border-2 border-[rgb(var(--color-bg-card))] animate-pulse pointer-events-none transform translate-y-20 opacity-0 scale-0 transition-all duration-260 ease-out"
  ></span>
</div>

<script>
  import * as Diff from 'diff'
  import { openDB, getStoredPosts, clearStore, savePosts, fetchRSS, generateId, NOTIFICATION_STATE_KEY, INIT_TIME_KEY } from '@/lib/notification-db'
  const LIST_ID = 'new-post-list'

  function computeDiff(oldText: string, newText: string) {
    if (!oldText || !newText) return null

    const normalizeRaw = (text: string) => {
      const s = String(text || '')
        .replace(/\r\n/g, '\n')
        .replace(/\r/g, '\n')
      const lines = s.split('\n').map((line) => line.replace(/[ \t]+$/g, ''))
      return lines.join('\n').trim()
    }

    const cleanOld = normalizeRaw(oldText)
    const cleanNew = normalizeRaw(newText)

    if (!cleanOld || !cleanNew) return null

    const diffs = Diff.diffLines(cleanOld, cleanNew)
    const hasChanges = diffs.some((part) => part.added || part.removed)

    if (!hasChanges) return null
    return diffs
  }

  function updatePanelTargetSize(panel: HTMLElement, newPosts: any[]) {
    const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16
    const maxPanelWidthPx = Math.min(20 * rootFontSize, window.innerWidth - 32)
    const minPanelWidthPx = Math.min(16 * rootFontSize, window.innerWidth - 32)

    let longestTitle = 0
    for (const post of newPosts) {
      if (!post?.title) continue
      longestTitle = Math.max(longestTitle, String(post.title).length)
    }

    const estimatedWidthRem = 14 + Math.min(longestTitle, 30) * 0.2
    const estimatedWidthPx = estimatedWidthRem * rootFontSize
    const openWidthPx = Math.max(minPanelWidthPx, Math.min(maxPanelWidthPx, estimatedWidthPx))
    panel.style.setProperty('--np-open-width', `${Math.round(openWidthPx)}px`)

    // Measure actual content height
    const sizer = document.createElement('div')
    sizer.style.position = 'fixed'
    sizer.style.left = '-10000px'
    sizer.style.top = '0'
    sizer.style.width = `${Math.round(openWidthPx)}px`
    sizer.style.maxHeight = 'none'
    sizer.style.overflow = 'visible'
    sizer.style.pointerEvents = 'none'
    sizer.style.visibility = 'hidden'

    const content = document.getElementById('notification-content')
    if (!content) return
    const clone = content.cloneNode(true) as HTMLElement
    clone.style.position = 'static'
    clone.style.inset = 'auto'
    clone.style.opacity = '1'
    clone.style.pointerEvents = 'auto'
    clone.style.transform = 'none'
    clone.querySelectorAll('[id]').forEach(el => el.removeAttribute('id'))
    const listEl = clone.querySelector('#new-post-list')
    if (listEl) {
      listEl.setAttribute('style', 'max-height: none; overflow: visible;')
    }

    sizer.appendChild(clone)
    document.body.appendChild(sizer)
    const measuredHeightPx = clone.scrollHeight + 4
    sizer.remove()

    const maxPanelHeightPx = Math.min(window.innerHeight * 0.7, 34 * rootFontSize)
    const minPanelHeightPx = 10 * rootFontSize
    const openHeightPx = Math.max(minPanelHeightPx, Math.min(maxPanelHeightPx, measuredHeightPx))
    panel.style.setProperty('--np-open-height', `${Math.round(openHeightPx)}px`)
  }

  function showNotification(newPosts: any[], timestamp: number, isFresh: boolean, initTime: number) {
    const minimizedBtn = document.getElementById('notification-minimized')
    const panel = document.getElementById('notification-panel') as HTMLElement
    const list = document.getElementById(LIST_ID)
    const dot = document.getElementById('notification-dot')
    const minimizeBtn = document.getElementById('minimize-notification')
    const clearBtn = document.getElementById('clear-notification')

    if (!panel || !list) return

    // Show panel
    requestAnimationFrame(() => {
      panel.classList.remove('translate-y-20', 'opacity-0')
      dot?.classList.remove('translate-y-20', 'opacity-0')
    })

    const initTimeStr = new Date(initTime).toLocaleString()
    const checkTimeStr = new Date(timestamp).toLocaleString()

    if (newPosts.length === 0) {
      list.innerHTML = `<div class="text-center text-[rgb(var(--color-text-2))] py-4">
        <p class="text-sm font-medium mb-2">暂无文章更新</p>
        <div class="text-xs opacity-70 bg-[rgb(var(--color-bg-soft))] rounded px-2 py-1 inline-block">
          ${initTimeStr} - ${checkTimeStr}
        </div>
      </div>`
      dot?.classList.add('scale-0')
      setupEventListeners()
      return
    }

    let html = `
      <div class="text-xs text-[rgb(var(--color-text-2))] mb-2 px-1 flex flex-col gap-0.5">
        <div class="font-medium">发现更新</div>
        <div class="opacity-70 text-[10px]">${initTimeStr} - ${checkTimeStr}</div>
      </div>`

    newPosts.forEach((post) => {
      const isUpdated = post.isUpdated
      const badge = isUpdated
        ? '<span class="text-xs bg-blue-500/20 text-blue-500 px-1.5 py-0.5 rounded ml-2">更新</span>'
        : '<span class="text-xs bg-green-500/20 text-green-500 px-1.5 py-0.5 rounded ml-2">新文章</span>'

      let postLink = post.link
      try {
        const url = new URL(post.link)
        postLink = url.pathname
      } catch {
        // Keep original if not a valid URL
      }

      let postHref = postLink
      if (isUpdated && post.diff) {
        try {
          const url = new URL(postLink, window.location.origin)
          url.searchParams.set('diff', '1')
          url.hash = 'post-diff'
          postHref = `${url.pathname}${url.search}${url.hash}`
        } catch {
          const base = postLink.split('#')[0]
          postHref = base.includes('?') ? `${base}&diff=1#post-diff` : `${base}?diff=1#post-diff`
        }
      }

      html += `
        <div>
          <div class="flex items-center justify-between p-2 rounded-lg hover:bg-[rgb(var(--color-primary))]/5 transition-colors">
            <a href="${postHref}" class="font-medium truncate pr-2 hover:text-[rgb(var(--color-primary))] transition-colors text-[rgb(var(--color-text))] block flex-1">
              ${post.title}
            </a>
            <div class="flex items-center shrink-0">
              ${badge}
            </div>
          </div>
        </div>`
    })

    list.innerHTML = html

    if (newPosts.length > 0) {
      dot?.classList.remove('scale-0')
      // Add visual indicator - animate the panel
      panel.style.animation = 'pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite'
      if (isFresh) {
        setTimeout(() => {
          openPanel()
        }, 1500)
      }
    } else {
      dot?.classList.add('scale-0')
      // Remove visual indicator
      panel.style.animation = ''
    }

    setupEventListeners()

    function openPanel() {
      updatePanelTargetSize(panel, newPosts)
      panel.classList.add('is-open')
      const prevTimer = panel.getAttribute('data-open-timer')
      if (prevTimer) {
        clearTimeout(Number(prevTimer))
      }
      const timer = window.setTimeout(() => {
        panel.classList.add('is-open-content')
        panel.removeAttribute('data-open-timer')
      }, 360)
      panel.setAttribute('data-open-timer', String(timer))
    }

    function closePanel() {
      const prevTimer = panel.getAttribute('data-open-timer')
      if (prevTimer) {
        clearTimeout(Number(prevTimer))
        panel.removeAttribute('data-open-timer')
      }
      panel.classList.remove('is-open-content')
      panel.classList.remove('is-open')
    }

    function setupEventListeners() {
      // Bind to the panel itself as primary click target
      panel.onclick = (e) => {
        // Don't close if clicking inside content area
        if (panel.classList.contains('is-open') && (e.target as HTMLElement).closest('#notification-content')) {
          return
        }
        if (!panel.classList.contains('is-open')) {
          openPanel()
        } else {
          closePanel()
        }
      }

      // Fallback to minimized button if exists
      if (minimizedBtn) {
        minimizedBtn.onclick = () => {
          if (!panel.classList.contains('is-open')) {
            openPanel()
          } else {
            closePanel()
          }
        }
      }

      if (minimizeBtn) {
        minimizeBtn.onclick = (e) => {
          e.stopPropagation()
          closePanel()
        }
      }

      if (clearBtn) {
        clearBtn.onclick = (e) => {
          e.stopPropagation()
          localStorage.removeItem(NOTIFICATION_STATE_KEY)
          const now = Date.now()
          localStorage.setItem(INIT_TIME_KEY, now.toString())
          showNotification([], now, false, now)
        }
      }

      if (!panel.hasAttribute('data-resize-listening')) {
        window.addEventListener('resize', () => {
          if (!panel.classList.contains('is-open')) return
          updatePanelTargetSize(panel, newPosts)
        })
        panel.setAttribute('data-resize-listening', 'true')
      }
    }
  }

  // Main logic
  async function init() {
    try {
      const currentPosts = await fetchRSS()
      if (currentPosts.length === 0) return

      const db = await openDB()
      const storedPostsOld = await getStoredPosts(db, 'posts')
      const storedPostsNew = await getStoredPosts(db, 'posts_new')
      let storedPosts = storedPostsOld
      if (storedPostsNew.length > 0) {
        storedPosts = storedPostsNew
        await clearStore(db, 'posts')
        await savePosts(db, 'posts', storedPostsNew)
      }

      let initTimestamp = localStorage.getItem(INIT_TIME_KEY)
      if (!initTimestamp) {
        initTimestamp = Date.now().toString()
        localStorage.setItem(INIT_TIME_KEY, initTimestamp)
      }
      const initTime = parseInt(initTimestamp)

      if (storedPostsOld.length === 0) {
        // First visit
        await clearStore(db, 'posts')
        await savePosts(db, 'posts', currentPosts)
        await clearStore(db, 'posts_new')
        localStorage.removeItem(NOTIFICATION_STATE_KEY)
        showNotification([], Date.now(), false, initTime)
      } else {
        await clearStore(db, 'posts_new')
        await savePosts(db, 'posts_new', currentPosts)

        const storedMap = new Map(
          storedPosts.map((p) => [p.id || generateId(p.guid), p]),
        )

        const detectedChanges: any[] = []

        currentPosts.forEach((post) => {
          const stored = storedMap.get(generateId(post.guid))
          if (!stored) {
            detectedChanges.push({ ...post, isUpdated: false })
          } else {
            const titleChanged = post.title !== stored.title
            const descriptionChanged = post.description !== stored.description
            const contentChanged = post.content !== stored.content

            if (titleChanged || descriptionChanged || contentChanged) {
              const result: any = {}
              let hasChanges = false

              if (contentChanged) {
                const d = computeDiff(stored.content, post.content)
                if (d) {
                  result.content = d
                  hasChanges = true
                }
              }

              if (descriptionChanged) {
                const d = Diff.diffLines(stored.description, post.description)
                if (d && d.some((p) => p.added || p.removed)) {
                  result.description = d
                  hasChanges = true
                }
              }

              if (titleChanged) {
                const d = Diff.diffLines(stored.title, post.title)
                if (d && d.some((p) => p.added || p.removed)) {
                  result.title = d
                  hasChanges = true
                }
              }

              if (hasChanges) {
                detectedChanges.push({
                  ...post,
                  isUpdated: true,
                  diff: result,
                  diffType: 'composite',
                })
              }
            }
          }
        })

        if (detectedChanges.length > 0) {
          const isAllNew =
            detectedChanges.length === currentPosts.length &&
            detectedChanges.every((p) => !p.isUpdated)
          const isAllUpdated =
            detectedChanges.length === currentPosts.length &&
            detectedChanges.every((p) => p.isUpdated)

          if (isAllNew || isAllUpdated) {
            console.log('[Notification] Intercepted "all new/updated" posts scenario.')
            await clearStore(db, 'posts')
            await savePosts(db, 'posts', currentPosts)
            await clearStore(db, 'posts_new')
            localStorage.removeItem(NOTIFICATION_STATE_KEY)
            showNotification([], Date.now(), false, initTime)
            return
          }

          const timestamp = Date.now()
          const state = { timestamp, items: detectedChanges }
          localStorage.setItem(NOTIFICATION_STATE_KEY, JSON.stringify(state))
          showNotification(detectedChanges, timestamp, true, initTime)
        } else {
          const persistedStateStr = localStorage.getItem(NOTIFICATION_STATE_KEY)
          if (persistedStateStr) {
            try {
              const state = JSON.parse(persistedStateStr)
              showNotification(state.items, state.timestamp, false, initTime)
            } catch (e) {
              showNotification([], Date.now(), false, initTime)
            }
          } else {
            showNotification([], Date.now(), false, initTime)
          }
        }
      }
    } catch (e) {
      console.error('New post check failed:', e)
    }
  }

  // Run on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }
</script>
