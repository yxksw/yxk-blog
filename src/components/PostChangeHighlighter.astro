---
// Post Change Highlighter - Shows update notification and highlights changes in article
// Based on fuwari's PostDiffInArticle implementation
---

<div id="post-change-notification" class="fixed top-24 right-4 z-50 transform translate-x-full opacity-0 transition-all duration-300 pointer-events-none">
  <div class="bg-secondary border border-accent rounded-xl shadow-lg p-4 max-w-sm relative pointer-events-auto flex flex-col gap-2">
    <div class="flex items-center gap-2 text-accent">
      <iconify-icon icon="lucide:file-diff" width="20" height="20"></iconify-icon>
      <span class="font-bold text-sm">内容已更新</span>
    </div>
    <p class="text-xs text-muted-foreground">检测到文章内容有变化，已为您高亮差异部分。</p>
    <div class="flex gap-2 mt-1">
      <button id="scroll-to-change" class="px-3 py-1 bg-accent text-accent-foreground rounded text-xs hover:opacity-90 transition-opacity">
        跳转到更新处
      </button>
      <button id="close-change-toast" class="px-3 py-1 bg-transparent border border-border text-foreground rounded text-xs hover:bg-secondary transition-colors">
        忽略
      </button>
    </div>
  </div>
</div>

<script>
  import { NOTIFICATION_STATE_KEY } from '@/lib/notification-db';

  const HIGHLIGHT_ADD_CLASS = 'post-inline-diff-add-target';
  const HIGHLIGHT_DEL_CLASS = 'post-inline-diff-del-target';
  const HIGHLIGHT_ADD_IMG_CLASS = 'post-inline-diff-add-target-img';
  const HIGHLIGHT_DEL_IMG_CLASS = 'post-inline-diff-del-target-img';
  
  async function initChangeCheck() {
    // Only run on post pages - try multiple selectors
    const articleContent = document.querySelector('.markdown-body, .markdown-content, article, [data-pagefind-body], .prose');
    if (!articleContent) {
      console.log('[PostChangeHighlighter] No article content found');
      return;
    }

    const currentPath = window.location.pathname;
    console.log('[PostChangeHighlighter] Current path:', currentPath);
    
    // Check if there's notification state
    const notificationState = localStorage.getItem(NOTIFICATION_STATE_KEY);
    if (!notificationState) {
      console.log('[PostChangeHighlighter] No notification state found');
      return;
    }

    try {
      const state = JSON.parse(notificationState);
      console.log('[PostChangeHighlighter] Notification state:', state);
      
      if (!state.items || state.items.length === 0) {
        console.log('[PostChangeHighlighter] No items in state');
        return;
      }

      // Find current article in the changes
      const currentArticleChange = state.items.find((item: any) => {
        if (!item.link) return false;
        
        try {
          // Handle both full URL and pathname
          let itemPath = item.link;
          if (item.link.startsWith('http')) {
            const url = new URL(item.link);
            itemPath = url.pathname;
          }
          
          console.log('[PostChangeHighlighter] Comparing:', itemPath, '===', currentPath);
          return itemPath === currentPath;
        } catch (e) {
          console.log('[PostChangeHighlighter] Error comparing:', e);
          return item.link === currentPath;
        }
      });

      console.log('[PostChangeHighlighter] Found change:', currentArticleChange);

      // Check if this article has changes (isUpdated or is a new post)
      if (!currentArticleChange) {
        console.log('[PostChangeHighlighter] No change found for this article');
        return;
      }

      // Show notification for both new posts and updated posts
      showChangeNotification();

      // Try to highlight changes if we have diff data
      if (currentArticleChange.diff && currentArticleChange.isUpdated) {
        console.log('[PostChangeHighlighter] Highlighting changes');
        applyInlineDiff(articleContent as HTMLElement, currentArticleChange.diff);
      } else if (!currentArticleChange.isUpdated) {
        console.log('[PostChangeHighlighter] New post, no diff to highlight');
      }
    } catch (e) {
      console.error('[PostChangeHighlighter] Failed to parse notification state:', e);
    }
  }

  function showChangeNotification() {
    const notification = document.getElementById('post-change-notification');
    if (!notification) return;

    notification.classList.remove('translate-x-full', 'opacity-0', 'pointer-events-none');

    document.getElementById('close-change-toast')?.addEventListener('click', () => {
      notification.classList.add('translate-x-full', 'opacity-0', 'pointer-events-none');
    });

    document.getElementById('scroll-to-change')?.addEventListener('click', () => {
      scrollToFirstHighlight();
      notification.classList.add('translate-x-full', 'opacity-0', 'pointer-events-none');
    });
  }

  // Helper functions for diff processing
  function normalizeLineText(text: string): string {
    return String(text ?? '')
      .replace(/\r\n/g, '\n')
      .replace(/\r/g, '\n')
      .replace(/\u00A0/g, ' ')
      .replace(/[ \t]*\n[ \t]*/g, ' ')
      .replace(/[ \t]{2,}/g, ' ')
      .replace(/[ \t]+$/g, '')
      .trim();
  }

  function extractImgSrc(line: string): string | null {
    const s = String(line ?? '');
    const m = s.match(/<img[^>]*\s(?:src|data-src)=["']([^"']+)["']/i);
    return m?.[1] ? String(m[1]).trim() : null;
  }

  function stripHtmlLine(line: string): string {
    const tmp = document.createElement('div');
    tmp.innerHTML = String(line ?? '');
    return tmp.textContent || tmp.innerText || '';
  }

  function normalizeForMatch(line: string): { kind: 'text' | 'img' | 'none', value: string } {
    const text = normalizeLineText(stripHtmlLine(line));
    if (text) return { kind: 'text', value: text };
    const imgSrc = extractImgSrc(line);
    if (imgSrc) return { kind: 'img', value: imgSrc };
    const raw = normalizeLineText(line);
    if (raw) return { kind: 'text', value: raw };
    return { kind: 'none', value: '' };
  }

  function findBlockByText(container: HTMLElement, line: string): HTMLElement | null {
    const key = normalizeForMatch(line);
    if (key.kind !== 'text') return null;
    const needle = key.value.slice(0, 48);
    const blocks = container.querySelectorAll('p, li, blockquote, pre, h1, h2, h3, h4, h5, h6');
    for (const el of blocks) {
      if (!(el instanceof HTMLElement)) continue;
      if (el.closest('.post-inline-diff-del-line')) continue;
      if (el.classList.contains('post-inline-diff-del-target')) continue;
      const content = el.textContent || '';
      if (!normalizeLineText(content).includes(needle)) continue;
      return el;
    }
    return null;
  }

  function findImgBySrc(container: HTMLElement, src: string): HTMLImageElement | null {
    const imgs = container.querySelectorAll('img');
    for (const img of imgs) {
      if (!(img instanceof HTMLImageElement)) continue;
      const imgSrc = img.getAttribute('src') || img.getAttribute('data-src') || '';
      if (imgSrc.includes(src) || src.includes(imgSrc)) return img;
    }
    return null;
  }

  function clearInlineDiff(container: HTMLElement) {
    container.querySelectorAll('[data-post-inline-diff]').forEach((el) => el.remove());
    container.querySelectorAll('[data-post-inline-diff-add-target]').forEach((el) => {
      el.removeAttribute('data-post-inline-diff-add-target');
      el.classList.remove(HIGHLIGHT_ADD_CLASS);
    });
    container.querySelectorAll('[data-post-inline-diff-del-target]').forEach((el) => {
      el.removeAttribute('data-post-inline-diff-del-target');
      el.classList.remove(HIGHLIGHT_DEL_CLASS);
    });
    container.querySelectorAll('[data-post-inline-diff-add-target-img]').forEach((el) => {
      el.removeAttribute('data-post-inline-diff-add-target-img');
      el.classList.remove(HIGHLIGHT_ADD_IMG_CLASS);
    });
    container.querySelectorAll('[data-post-inline-diff-del-target-img]').forEach((el) => {
      el.removeAttribute('data-post-inline-diff-del-target-img');
      el.classList.remove(HIGHLIGHT_DEL_IMG_CLASS);
    });
  }

  function applyInlineDiff(container: HTMLElement, diffData: any) {
    clearInlineDiff(container);
    
    let diffParts: any[] = [];
    
    if (diffData.content && Array.isArray(diffData.content)) {
      diffParts = diffData.content;
    } else if (Array.isArray(diffData)) {
      diffParts = diffData;
    }

    if (diffParts.length === 0) {
      console.log('[PostChangeHighlighter] No diff parts found');
      return;
    }

    console.log('[PostChangeHighlighter] Processing', diffParts.length, 'diff parts');

    // Process diff parts
    let anchorInserted = false;
    
    for (let i = 0; i < diffParts.length; i++) {
      const part = diffParts[i];
      
      if (part.added) {
        // Handle added content
        const lines = part.value.split('\n').filter((l: string) => l.trim());
        
        for (const line of lines) {
          const key = normalizeForMatch(line);
          
          if (key.kind === 'img') {
            // Handle added image
            const img = findImgBySrc(container, key.value);
            if (img) {
              img.classList.add(HIGHLIGHT_ADD_IMG_CLASS);
              img.setAttribute('data-post-inline-diff-add-target-img', '1');
              
              if (!anchorInserted) {
                const anchor = document.createElement('span');
                anchor.id = 'post-diff';
                anchor.setAttribute('data-post-inline-diff', '1');
                img.parentNode?.insertBefore(anchor, img);
                anchorInserted = true;
              }
            }
          } else if (key.kind === 'text') {
            // Handle added text - find the block and add highlight class
            const target = findBlockByText(container, line);
            if (target) {
              target.classList.add(HIGHLIGHT_ADD_CLASS);
              target.setAttribute('data-post-inline-diff-add-target', '1');
              
              if (!anchorInserted) {
                const anchor = document.createElement('span');
                anchor.id = 'post-diff';
                anchor.setAttribute('data-post-inline-diff', '1');
                target.parentNode?.insertBefore(anchor, target);
                anchorInserted = true;
              }
            }
          }
        }
      } else if (part.removed) {
        // Handle removed content - mark existing elements as deleted
        const lines = part.value.split('\n').filter((l: string) => l.trim());
        
        for (const line of lines) {
          const key = normalizeForMatch(line);
          
          if (key.kind === 'img') {
            const img = findImgBySrc(container, key.value);
            if (img) {
              img.classList.add(HIGHLIGHT_DEL_IMG_CLASS);
              img.setAttribute('data-post-inline-diff-del-target-img', '1');
            }
          } else if (key.kind === 'text') {
            const target = findBlockByText(container, line);
            if (target) {
              target.classList.add(HIGHLIGHT_DEL_CLASS);
              target.setAttribute('data-post-inline-diff-del-target', '1');
            }
          }
        }
        
        // Check for replacement pattern (del followed by add)
        if (i + 1 < diffParts.length && diffParts[i + 1].added) {
          const nextPart = diffParts[i + 1];
          const nextLines = nextPart.value.split('\n').filter((l: string) => l.trim());
          
          // Try to pair removed and added lines
          for (let j = 0; j < Math.min(lines.length, nextLines.length); j++) {
            const oldLine = lines[j];
            const newLine = nextLines[j];
            
            const oldKey = normalizeForMatch(oldLine);
            const newKey = normalizeForMatch(newLine);
            
            if (newKey.kind === 'text') {
              const target = findBlockByText(container, newLine);
              if (target) {
                // This is a replacement - add both del and add styling
                target.classList.add(HIGHLIGHT_ADD_CLASS);
                target.setAttribute('data-post-inline-diff-add-target', '1');
                
                // Insert a deletion node before the target
                const delNode = createDeletionNode(oldKey.kind === 'img' ? `[图片] ${oldKey.value}` : oldKey.value, !anchorInserted);
                if (!anchorInserted) anchorInserted = true;
                target.parentNode?.insertBefore(delNode, target);
              }
            } else if (newKey.kind === 'img') {
              const img = findImgBySrc(container, newKey.value);
              if (img) {
                img.classList.add(HIGHLIGHT_ADD_IMG_CLASS);
                img.setAttribute('data-post-inline-diff-add-target-img', '1');
              }
            }
          }
          
          i++; // Skip the next part since we processed it
        }
      }
    }

    console.log('[PostChangeHighlighter] Diff highlighting complete');
  }

  function createDeletionNode(text: string, includeAnchor: boolean): HTMLElement {
    const el = document.createElement('div');
    el.setAttribute('data-post-inline-diff', '1');
    el.className = 'post-inline-diff-del-line';

    if (includeAnchor) {
      const anchor = document.createElement('span');
      anchor.id = 'post-diff';
      anchor.setAttribute('data-post-inline-diff', '1');
      el.appendChild(anchor);
    }

    const del = document.createElement('del');
    del.textContent = ` ${text}`;
    el.appendChild(del);
    
    return el;
  }

  function scrollToFirstHighlight() {
    const firstHighlight = document.querySelector('[data-post-inline-diff-add-target], [data-post-inline-diff-add-target-img], #post-diff');
    if (firstHighlight) {
      firstHighlight.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Add a flash animation
      const element = firstHighlight as HTMLElement;
      const originalTransition = element.style.transition;
      element.style.transition = 'all 0.3s ease';
      element.style.transform = 'scale(1.02)';
      
      setTimeout(() => {
        element.style.transform = 'scale(1)';
        element.style.transition = originalTransition;
      }, 300);
    }
  }

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initChangeCheck);
  } else {
    initChangeCheck();
  }
</script>

<style is:global>
  /* Added content styling - green underline */
  .post-inline-diff-add-target {
    text-decoration-line: underline !important;
    text-decoration-thickness: 3px !important;
    text-underline-offset: 0.2em !important;
    text-decoration-color: rgb(34 197 94) !important; /* green-500 */
    background-color: rgba(34, 197, 94, 0.1) !important;
    border-radius: 0.25rem;
    padding: 0.125rem 0.25rem;
    transition: all 0.3s ease;
  }

  /* Added image styling - green outline */
  .post-inline-diff-add-target-img {
    outline: 3px solid rgb(34 197 94) !important; /* green-500 */
    outline-offset: 3px !important;
    border-radius: 0.5rem !important;
    background-color: rgba(34, 197, 94, 0.1) !important;
    transition: all 0.3s ease;
  }

  /* Deleted content styling - red strikethrough */
  .post-inline-diff-del-target {
    color: rgb(239 68 68) !important; /* red-500 */
    text-decoration-line: line-through !important;
    text-decoration-thickness: 3px !important;
    text-decoration-color: rgb(239 68 68) !important;
    opacity: 0.8;
  }

  /* Deleted image styling - red outline */
  .post-inline-diff-del-target-img {
    outline: 3px solid rgb(239 68 68) !important; /* red-500 */
    outline-offset: 3px !important;
    border-radius: 0.5rem !important;
    opacity: 0.6 !important;
    filter: grayscale(0.5);
  }

  /* Deleted line block styling */
  .post-inline-diff-del-line {
    margin: 0.75rem 0;
    padding: 0.5rem 0.75rem;
    background-color: rgba(239, 68, 68, 0.1);
    border-left: 4px solid rgb(239 68 68);
    border-radius: 0 0.375rem 0.375rem 0;
    color: rgb(239 68 68);
    font-size: 0.9em;
  }

  .post-inline-diff-del-line del {
    text-decoration-thickness: 2px;
    color: inherit;
  }

  /* Hover effects */
  .post-inline-diff-add-target:hover {
    background-color: rgba(34, 197, 94, 0.2) !important;
  }

  .post-inline-diff-add-target-img:hover {
    outline-width: 4px !important;
    outline-offset: 4px !important;
  }

  /* Animation for newly highlighted elements */
  @keyframes diff-highlight-pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  .post-inline-diff-add-target,
  .post-inline-diff-add-target-img {
    animation: diff-highlight-pulse 2s ease-in-out 2;
  }

  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .post-inline-diff-add-target {
      text-decoration-color: rgb(74 222 128) !important; /* green-400 */
      background-color: rgba(74, 222, 128, 0.15) !important;
    }

    .post-inline-diff-add-target-img {
      outline-color: rgb(74 222 128) !important;
      background-color: rgba(74, 222, 128, 0.15) !important;
    }

    .post-inline-diff-del-target {
      color: rgb(248 113 113) !important; /* red-400 */
      text-decoration-color: rgb(248 113 113) !important;
    }

    .post-inline-diff-del-target-img {
      outline-color: rgb(248 113 113) !important;
    }

    .post-inline-diff-del-line {
      background-color: rgba(248, 113, 113, 0.15);
      border-left-color: rgb(248 113 113);
      color: rgb(248 113 113);
    }
  }
</style>
