---
import type { TimetableCourseView } from '@/types/timetable';

interface Props {
  course: TimetableCourseView;
  compact?: boolean;
  showTime?: boolean;
}

const { course, compact = false, showTime = false } = Astro.props;
const borderColor = course.color || '#6b7280';

// 处理颜色，提取RGB值用于背景
function hexToRgba(hex: string, alpha: number): string {
  let cleanHex = hex.replace('#', '');
  // 处理8位hex（带alpha）
  if (cleanHex.length === 8) {
    cleanHex = cleanHex.slice(0, 6);
  }
  // 处理3位hex
  if (cleanHex.length === 3) {
    cleanHex = cleanHex.split('').map(c => c + c).join('');
  }
  const r = parseInt(cleanHex.substr(0, 2), 16);
  const g = parseInt(cleanHex.substr(2, 2), 16);
  const b = parseInt(cleanHex.substr(4, 2), 16);
  return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

const bgColor = hexToRgba(borderColor, 0.75);
const borderLeftColor = borderColor;
---

<article
  class:list={[
    'course-card rounded-lg shadow-sm hover:shadow-md transition-all',
    compact ? 'p-2.5' : 'p-3',
  ]}
  style={`background: linear-gradient(135deg, ${bgColor} 0%, ${hexToRgba(borderColor, 0.65)} 100%); border: 1px solid ${hexToRgba(borderColor, 0.5)}; border-left: 4px solid ${borderLeftColor};`}
>
  <div class="flex items-start justify-between gap-2">
    <h3
      class:list={[
        'font-semibold leading-tight line-clamp-2 course-title',
        compact ? 'text-xs' : 'text-sm',
      ]}
    >
      {course.courseName}
    </h3>
    <span class="text-[10px] whitespace-nowrap opacity-80 course-meta"
      >{course.startWeek}-{course.endWeek}周</span
    >
  </div>
  {
    showTime && (
      <p
        class:list={[
          'mt-1 opacity-90 course-meta',
          compact ? 'text-[11px]' : 'text-xs',
        ]}
      >
        时间：{course.timeText}
      </p>
    )
  }
  <p
    class:list={[
      showTime ? 'mt-0.5' : 'mt-1',
      'opacity-90 course-meta',
      compact ? 'text-[11px]' : 'text-xs',
    ]}
  >
    教室：{course.room}
  </p>
  <p
    class:list={[
      'mt-0.5 opacity-90 course-meta',
      compact ? 'text-[11px]' : 'text-xs',
    ]}
  >
    教师：{course.teacher}
  </p>
</article>

<style is:global>
  /* 默认浅色模式：黑色文字 */
  .course-card .course-title {
    color: rgb(0, 0, 0) !important;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.3);
  }
  
  .course-card .course-meta {
    color: rgba(0, 0, 0, 0.8) !important;
  }
  
  /* 深色模式：白色文字 */
  @media (prefers-color-scheme: dark) {
    .course-card .course-title {
      color: rgb(255, 255, 255) !important;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
    
    .course-card .course-meta {
      color: rgba(255, 255, 255, 0.9) !important;
    }
  }
  
  /* 适配博客的 data-theme="dark" */
  html[data-theme="dark"] .course-card .course-title,
  [data-theme="dark"] .course-card .course-title {
    color: rgb(255, 255, 255) !important;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }
  
  html[data-theme="dark"] .course-card .course-meta,
  [data-theme="dark"] .course-card .course-meta {
    color: rgba(255, 255, 255, 0.9) !important;
  }
  
  /* 浅色模式 */
  html[data-theme="light"] .course-card .course-title,
  [data-theme="light"] .course-card .course-title {
    color: rgb(0, 0, 0) !important;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.3);
  }
  
  html[data-theme="light"] .course-card .course-meta,
  [data-theme="light"] .course-card .course-meta {
    color: rgba(0, 0, 0, 0.8) !important;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
