---
import type { TimetableViewModel } from '@/types/timetable';
import LiveTimetableStatus from './LiveTimetableStatus.astro';
import TimetableDayList from './TimetableDayList.astro';
import TimetableGrid from './TimetableGrid.astro';
import TimetableVisualEditor from './TimetableVisualEditor.svelte';
import TimetableEditor from './TimetableEditor.svelte';
import { Icon } from 'astro-icon/components';

interface Props {
  viewModel: TimetableViewModel;
  isCurrentWeek?: boolean;
  jsonText?: string;
  startDate?: string;
  maxWeek?: number;
}

const { viewModel, isCurrentWeek = false, jsonText = '', startDate = '', maxWeek = 20 } = Astro.props;

const liveStatusPayload = {
  coursesByDay: viewModel.coursesByDay,
};
---

<div class="card-base p-6 md:p-8 rounded-xl border border-border bg-card">
  <div class="flex items-center gap-3 mb-4">
    <div class="h-10 w-10 rounded-lg bg-accent flex items-center justify-center shrink-0">
      <Icon name="lucide:calendar-days" class="text-xl text-accent-foreground" />
    </div>
    <div class="flex-1">
      <h1 class="text-xl font-bold text-foreground">{viewModel.tableName}</h1>
      <p class="text-sm text-muted-foreground">共 {viewModel.maxWeek} 周</p>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-3 mb-5 text-sm">
    <div class="inline-flex items-center gap-1" id="week-navigator" data-start-date={startDate} data-max-week={maxWeek} data-server-week={viewModel.currentWeek}>
      <a
        id="prev-week-link"
        href={`/timetable/${Math.max(1, viewModel.currentWeek - 1)}/`}
        class:list={[
          'h-9 w-9 rounded-lg flex items-center justify-center font-medium border border-border bg-secondary hover:bg-secondary/80 transition-colors',
          { 'pointer-events-none opacity-50': viewModel.currentWeek <= 1 },
        ]}
        aria-label="上一周"
      >
        <Icon name="lucide:chevron-left" class="text-lg" />
      </a>
      <span id="current-week-display" class="min-w-[4.5rem] px-1 text-center font-medium text-foreground"
        >第 {viewModel.currentWeek} 周</span
      >
      <a
        id="next-week-link"
        href={`/timetable/${Math.min(viewModel.maxWeek, viewModel.currentWeek + 1)}/`}
        class:list={[
          'h-9 w-9 rounded-lg flex items-center justify-center font-medium border border-border bg-secondary hover:bg-secondary/80 transition-colors',
          { 'pointer-events-none opacity-50': viewModel.currentWeek >= viewModel.maxWeek },
        ]}
        aria-label="下一周"
      >
        <Icon name="lucide:chevron-right" class="text-lg" />
      </a>
      {
        isCurrentWeek && (
          <span id="current-week-badge" class="rounded-lg border border-emerald-400/30 bg-emerald-500/10 px-2.5 py-1 text-sm font-medium text-emerald-500 leading-none">
            当前周
          </span>
        )
      }
    </div>
  </div>

  <script is:inline>
    // 客户端实时计算当前周
    (function() {
      const navigator = document.getElementById('week-navigator');
      if (!navigator) return;
      
      const startDate = navigator.dataset.startDate;
      const maxWeek = parseInt(navigator.dataset.maxWeek || '20', 10);
      const serverWeek = parseInt(navigator.dataset.serverWeek || '1', 10);
      
      if (!startDate) return;
      
      // 解析日期
      function parseDateFromYmd(ymd) {
        const parts = ymd.split('-').map((part) => Number(part));
        if (parts.length !== 3 || parts.some((part) => !Number.isFinite(part))) {
          return null;
        }
        const [year, month, day] = parts;
        return new Date(year, month - 1, day);
      }
      
      // 计算当前周
      function resolveCurrentWeek(startDateText, maxWeekNum) {
        const startDate = parseDateFromYmd(startDateText);
        if (!startDate) return 1;
        
        const now = new Date();
        const msPerDay = 24 * 60 * 60 * 1000;
        const diffDays = Math.floor((now.getTime() - startDate.getTime()) / msPerDay);
        const week = Math.floor(diffDays / 7) + 1;
        
        if (week < 1) return 1;
        if (week > maxWeekNum) return maxWeekNum;
        return week;
      }
      
      const clientCurrentWeek = resolveCurrentWeek(startDate, maxWeek);
      
      // 如果客户端计算的周数与服务器不同，更新显示
      if (clientCurrentWeek !== serverWeek) {
        const weekDisplay = document.getElementById('current-week-display');
        const prevLink = document.getElementById('prev-week-link');
        const nextLink = document.getElementById('next-week-link');
        const badge = document.getElementById('current-week-badge');
        
        if (weekDisplay) {
          weekDisplay.textContent = `第 ${clientCurrentWeek} 周`;
        }
        
        // 更新链接
        if (prevLink) {
          prevLink.href = `/timetable/${Math.max(1, clientCurrentWeek - 1)}/`;
          prevLink.classList.toggle('pointer-events-none', clientCurrentWeek <= 1);
          prevLink.classList.toggle('opacity-50', clientCurrentWeek <= 1);
        }
        
        if (nextLink) {
          nextLink.href = `/timetable/${Math.min(maxWeek, clientCurrentWeek + 1)}/`;
          nextLink.classList.toggle('pointer-events-none', clientCurrentWeek >= maxWeek);
          nextLink.classList.toggle('opacity-50', clientCurrentWeek >= maxWeek);
        }
        
        // 显示当前周标记
        if (badge) {
          badge.style.display = 'inline-block';
        }
        
        // 更新页面标题
        document.title = `课表 - 第${clientCurrentWeek}周`;
      } else {
        // 即使周数相同，也更新标题
        document.title = `课表 - 第${serverWeek}周`;
      }
    })();
  </script>

  <LiveTimetableStatus payload={liveStatusPayload} class="mb-4" />

  <TimetableVisualEditor client:load viewModel={viewModel} />

  {jsonText && <TimetableEditor client:load viewModel={viewModel} jsonText={jsonText} />}

  <p class="text-xs text-muted-foreground mb-4">
    提示：周次切换后将展示该周实际有课的安排，多周课程会在对应周自动出现。
  </p>

  <TimetableGrid viewModel={viewModel} />
  <TimetableDayList viewModel={viewModel} />
</div>
